# =============================================================================
# A&E Smart Routing — Environment Configuration
# =============================================================================
# Pick exactly one provider: "watsonx" | "custom" | "mock"
LLM_PROVIDER=mock

# -----------------------------------------------------------------------------
# IBM watsonx.ai — fill these to use IBM Cloud foundation models.
# -----------------------------------------------------------------------------
WATSONX_APIKEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# -----------------------------------------------------------------------------
# OpenAI-compatible / open-source endpoint (vLLM, Ollama, LM Studio, OpenAI…).
# -----------------------------------------------------------------------------
CUSTOM_LLM_BASE_URL=http://localhost:8080/v1
CUSTOM_LLM_API_KEY=not-needed
CUSTOM_LLM_MODEL=llama-3.1-8b-instruct

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000

# Default user location used when geolocation is unavailable (Manchester city centre).
DEFAULT_LAT=53.4808
DEFAULT_LON=-2.2426
